{
  "name": "snapline-hub",
  "version": "0.2.4",
  "description": "Optional reporting UI for Snapline test execution results",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "build": "npm run build:packages && npm run build:web && npm run build:server",
    "build:packages": "npm run build -w @vaagatech/snapline-hub-core",
    "build:web": "vite build --config web/vite.config.ts",
    "build:server": "tsc -p tsconfig.server.json",
    "build:ui-package": "npm run build -w @vaagatech/snapline-hub-ui",
    "build:api-package": "npm run build -w @vaagatech/snapline-hub-api",
    "start": "node dist/server/index.js",
    "seed:demos": "tsx scripts/seed-demos.ts",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "npm run build:packages && tsc -p tsconfig.server.json --noEmit && tsc -p web/tsconfig.json --noEmit",
    "sync-versions": "node scripts/sync-versions.mjs",
    "publish:packages": "npm run build:packages && npm run build:api-package && npm run build:ui-package && npm publish -w @vaagatech/snapline-hub-core && npm publish -w @vaagatech/snapline-hub-api && npm publish -w @vaagatech/snapline-hub-ui"
  },
  "dependencies": {
    "@vaagatech/snapline-hub-core": "0.2.4",
    "better-sqlite3": "^11.9.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "pg": "^8.16.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.14.1",
    "@types/pg": "^8.15.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.2",
    "supertest": "^7.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vitest": "^3.1.2"
  },
  "engines": {
    "node": ">=18"
  }
}
