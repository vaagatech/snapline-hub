{
  "name": "@vaagatech/snapline-hub-ui",
  "version": "0.2.4",
  "description": "Embeddable React UI for Snapline Hub test reporting",
  "author": "VaagaTech (https://www.vaagatech.com)",
  "license": "MIT",
  "homepage": "https://vaagatech.github.io/snapline-hub/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vaagatech/snapline-hub.git",
    "directory": "packages/ui"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "vite build --config vite.config.ts && cp types/index.d.ts dist/index.d.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "react-router-dom": ">=6"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
