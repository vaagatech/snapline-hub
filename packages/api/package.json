{
  "name": "@vaagatech/snapline-hub-api",
  "version": "0.2.6",
  "description": "Embeddable Express API for Snapline Hub test reporting",
  "author": "VaagaTech (https://www.vaagatech.com)",
  "license": "MIT",
  "homepage": "https://vaagatech.github.io/snapline-hub/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vaagatech/snapline-hub.git",
    "directory": "packages/api"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
